# Polymarket wallet private key (EOA — MetaMask / hardware wallet)
POLYMARKET_PRIVATE_KEY=0xyour_private_key_here

# Polymarket CLOB endpoints (defaults point to mainnet)
CLOB_API_URL=https://clob.polymarket.com
CLOB_WS_URL=wss://ws-subscriptions-clob.polymarket.com/ws/

# Binance WebSocket for BTC price feed
BINANCE_WS_URL=wss://stream.binance.com:9443/ws

# Trading parameters
BTC_SYMBOL=BTCUSDT
ORDER_SIZE_USDC=50           # Size per maker order in USDC (6 decimals internally)
MAX_OPEN_ORDERS=4            # Max simultaneous open orders per market (2 YES + 2 NO)
TARGET_PRICE_YES=0.92        # Target price to quote YES side (92 cents)
TARGET_PRICE_NO=0.92         # Target price to quote NO side (92 cents)

# Timing
QUOTE_REFRESH_MS=200         # Re-evaluate quotes every 200ms
CANCEL_REPLACE_TIMEOUT_MS=90 # Hard deadline for cancel/replace round-trip
ENTRY_WINDOW_SEC=10          # Enter positions this many seconds before market close
EXIT_WINDOW_SEC=2            # Stop quoting this many seconds before close (avoid fills after resolution)

# Risk — Exposure
MAX_EXPOSURE_USDC=500        # Max total exposure across all open markets (ENFORCED)
MIN_EDGE_BPS=50              # Skip market if expected edge < 50bps

# Risk — Drawdown & loss limits
MAX_DRAWDOWN_USDC=100        # Halt trading if session drawdown exceeds this
MAX_DAILY_LOSS_USDC=200      # Halt trading if daily losses exceed this
MAX_CONSECUTIVE_LOSSES=5     # Pause trading after N consecutive losses
CIRCUIT_BREAKER_COOLDOWN_SEC=600  # Seconds to pause after circuit breaker triggers

# Risk — Kelly position sizing
KELLY_ENABLED=true           # Use Kelly criterion for position sizing
KELLY_FRACTION=0.25          # Fraction of Kelly to use (0.25 = quarter-Kelly)

# Volatility gate
VOLATILITY_GATE_BPS=200      # Skip trading if 5m candle range > this (bps)

# Signal
OFI_WEIGHT=0.15              # Order-flow imbalance weight in composite signal

# Staleness
STALENESS_THRESHOLD_MS=2000  # Cancel orders if price data older than this (ms)

# Paper trading
PAPER_MODE=false             # Set to true for paper trading (no real orders)

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=text              # "text" for human-readable, "json" for structured
STATS_LOG_INTERVAL=10        # Log stats every N window rollovers

# Dashboard (web UI for monitoring)
DASHBOARD_PORT=8080              # Web server port
DASHBOARD_HOST=0.0.0.0           # 0.0.0.0 for external access, 127.0.0.1 for local only
DASHBOARD_PASSWORD=              # Basic auth password (empty = no auth)
