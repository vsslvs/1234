# Polymarket wallet private key (EOA — MetaMask / hardware wallet)
POLYMARKET_PRIVATE_KEY=0xyour_private_key_here

# Polymarket CLOB endpoints (defaults point to mainnet)
CLOB_API_URL=https://clob.polymarket.com
CLOB_WS_URL=wss://ws-subscriptions-clob.polymarket.com/ws/

# Binance WebSocket for BTC price feed
BINANCE_WS_URL=wss://stream.binance.com:9443/ws

# Trading parameters
BTC_SYMBOL=BTCUSDT
ORDER_SIZE_USDC=50           # Size per maker order in USDC (6 decimals internally)
MAX_OPEN_ORDERS=4            # Max simultaneous open orders per market (2 YES + 2 NO)
MAX_ENTRY_PRICE=0.95         # Max price to pay for any outcome token (dynamic pricing)
BREAKEVEN_SAFETY_BPS=200     # p_signal must exceed break-even by this margin (bps)

# Timing
QUOTE_REFRESH_MS=200         # Re-evaluate quotes every 200ms
CANCEL_REPLACE_TIMEOUT_MS=90 # Hard deadline for cancel/replace round-trip
ENTRY_WINDOW_SEC=10          # Enter positions this many seconds before market close
EXIT_WINDOW_SEC=2            # Stop quoting this many seconds before close (avoid fills after resolution)

# Risk
MAX_EXPOSURE_USDC=500        # Max total exposure across all open markets
MIN_EDGE_BPS=200             # Skip market if expected edge < 200bps

# Stop-loss & hedge improvements
STOP_LOSS_ENABLED=true       # Enable early exit when signal reverses against filled position
STOP_LOSS_THRESHOLD=0.12     # Signal reversal threshold to trigger stop-loss (12%)
HEDGE_TIMEOUT_SEC=25         # Seconds before aggressive hedge tightening (was 60)
SELL_EXIT_ENABLED=true       # Sell filled tokens during hedge timeout to cap losses
QUIET_PERIOD_SEC=35          # Skip quoting in first N seconds of window (was 60)

# Polymarket fee model (exact formula: fee = C × p × feeRate × (p×(1-p))^exponent)
# Current Crypto category values. Update on 2026-03-30:
#   FEE_RATE=0.072  FEE_EXPONENT=1
FEE_RATE=0.25                # Crypto category fee rate
FEE_EXPONENT=2               # Crypto category exponent (→1 after 2026-03-30)
MAKER_REBATE_PCT=0.20        # 20% of taker fees redistributed to makers
FEE_CACHE_TTL_SEC=300        # Cache fee-rate API response for 5 minutes

# Logging
LOG_LEVEL=INFO
